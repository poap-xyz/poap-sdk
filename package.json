{
  "name": "@poap-xyz/poap-sdk",
  "version": "0.22.1",
  "description": "SDK for everything POAP",
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.mjs",
  "browser": "dist/umd/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    "require": "./dist/cjs/index.cjs",
    "import": "./dist/esm/index.mjs",
    "browser": "./dist/umd/index.js",
    "types": "./dist/types/index.d.ts"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/poap-xyz/poap-sdk"
  },
  "author": "POAP",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/poap-xyz/poap.js/issues"
  },
  "homepage": "https://github.com/poap-xyz/poap.js#readme",
  "scripts": {
    "build:js": "rollup -c --bundleConfigAsCjs",
    "build:types": "tsc -p tsconfig.json",
    "build": "pnpm build:js && pnpm build:types",
    "lint": "eslint './src/**/*.ts'",
    "lint:fix": "eslint './src/**/*.ts' --fix",
    "format": "prettier --write './src/**/*.ts'",
    "publish.sdk": "./scripts/publish-sdk",
    "publish.beta": "./scripts/publish-beta",
    "test": "jest",
    "type-check:build": "npx tsc -p tsconfig.build.json --noEmit",
    "type-check:types": "npx tsc -p tsconfig.json --noEmit",
    "type-check": "pnpm type-check:build && pnpm type-check:types"
  },
  "dependencies": {
    "lodash.chunk": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@jest/globals": "^30.3.0",
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/jest": "^30.0.0",
    "@types/lodash.chunk": "^4.2.9",
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.39.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jest-fetch-mock": "^3.0.3",
    "jest-mock-extended": "^4.0.0",
    "prettier": "^3.8.1",
    "rollup": "^4.59.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
